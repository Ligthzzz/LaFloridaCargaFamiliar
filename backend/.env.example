NODE_ENV=development
PORT=3000

JWT_SECRET=change-me-dev-secret-change-me-dev-secret
JWT_EXPIRES_IN=8h

# Uso local (docker-compose): se usan estas 5 variables.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=laflorida
DB_PASSWORD=laflorida
DB_DATABASE=carga_familiar

# Uso en la nube (Railway, etc.): si DATABASE_URL está definida, reemplaza
# las 5 variables de arriba y se conecta con SSL automáticamente.
# DATABASE_URL=postgresql://usuario:password@host:puerto/basededatos

# true (por defecto) crea/actualiza las tablas automáticamente al iniciar.
# Ponerla en false una vez que el sistema esté en un ambiente real con datos
# importantes, para evitar cambios accidentales de esquema.
DB_SYNCHRONIZE=true

SEED_ADMIN_EMAIL=admin@laflorida.cl
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_RUT=11.111.111-4
SEED_ADMIN_NOMBRE=Administrador

UPLOADS_DIR=uploads
FRONTEND_ORIGIN=http://localhost:5173
